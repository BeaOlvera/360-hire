# Anthropic Claude (interview chat, scoring, profile generation)
ANTHROPIC_API_KEY=

# OpenAI (Whisper for live transcription of the interview audio)
OPENAI_API_KEY=

# Supabase (SEPARATE project from 360_app)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (candidate invitation emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Vercel Blob (CV uploads, continuous interview video)
BLOB_READ_WRITE_TOKEN=

# App URL used in candidate invitation links
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Admin password (CHANGE THIS for production)
ADMIN_PASSWORD=admin123

# PDF rendering, ONLY needed for local dev (Vercel uses @sparticuz/chromium automatically).
# Point this to your local Chrome / Edge / Brave binary so the PDF endpoint works locally.
# Windows examples:
#   C:/Program Files/Google/Chrome/Application/chrome.exe
#   C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe
CHROME_EXECUTABLE_PATH=
